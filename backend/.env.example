# MongoDB connection (Railway provides MONGO_URL automatically when you add MongoDB plugin)
MONGO_URL=mongodb://localhost:27017
DB_NAME=aegis_os

# CORS - set to your frontend URL in production, * during local testing
CORS_ORIGINS=*

# Anthropic API key (https://console.anthropic.com/) - optional
# Without this, AI Gateway falls back to deterministic mock.
ANTHROPIC_API_KEY=

# BDIA ledger signing key - MUST be set in production.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
BDIA_HMAC_KEY=change-me-generate-a-random-64-char-hex-string

# LLM model override (optional)
LLM_MODEL=claude-sonnet-4-5-20250929
